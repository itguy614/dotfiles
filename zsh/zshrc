# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:/usr/local/bin:$PATH

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set a smart terminal
export TERM=xterm-256color

ZSH_THEME="gallifrey"
HYPHEN_INSENSITIVE="true"
COMPLETION_WAITING_DOTS="true"
HIST_STAMPS="yyyy-mm-dd"
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt AUTO_CD

VI_MODE_SET_CURSOR="true"
VI_MODE_RESET_PROMPT_ON_MODE_CHANGE="true"

export EDITOR=nvim
export VISUAL=nvim

plugins=(
    fzf-tab
    colored-man-pages
    colorize
    common-aliases
    composer
    cp
    direnv
    extract
    git
    gitignore
    npm
    pip
    python
    sudo
    tmux
    vi-mode
    vscode
    web-search
    aws
    zsh-autosuggestions
    zsh-completions
    zsh-history-substring-search
    zsh-syntax-highlighting)

export KEYTIMEOUT=15

typeset -U path cdpath fpath
path=(
	$HOME/.local/bin
	./bin
	./vendor/bin
	/usr/local/bin
	/usr/local/sbin
	$HOME/.composer/vendor/bin
	$HOME/bin
    $path
)

# Easier directory navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias .2="cd ../.."
alias .3="cd ../../.."
alias .4="cd ../../../.."
alias ~="cd ~"

# Shortcuts
alias p="cd $HOME/code"
alias v="nvim"
alias vim="nvim"

# PHP/Laravel Shortcuts
alias tinker="php artisan tinker"
alias tink="php artisan tinker"

alias art="php artisan"

alias migrate="php artisan migrate"
alias mfs="php artisan migrate:fresh --seed"

alias mc="php artisan make:controller"
alias mrc="php artisan make:controller --resource"
alias mm="php artisan make:migration"
alias mmm="php artisan make:migration -m"

# Tail all Laravel Logs and filter out the stack traces:
alias viewlog='tail -f -n 450 storage/logs/laravel*.log | grep -i -E "^\[\d{4}\-\d{2}\-\d{2} \d{2}:\d{2}:\d{2}\]|Next [\w\W]+?\:" --color'

# Remove all logs
alias rmlogs="rm storage/logs/laravel-*.log"

alias c="composer"
alias cr="composer require"
alias cda="composer dumpautoload"
alias cu="composer update"

alias mylocal="mysql -u root -p -h localhost --protocol tcp"

# Espressif environment
alias goesp=". $HOME/esp/esp-idf/export.sh"
alias esp="idf.py"
alias ef="idf.py"

# GIT Shortcuts
alias g="git"
alias ga="git add "
alias gaa="git add -A"
alias gamd="git commit --amend --no-edit"
alias gb="git branch "
alias gbc="git checkout -b"
alias gbr="git branch"
alias gbrc="git rev-parse --abbrev-ref HEAD"
alias gc="git commit"
alias gcl="git clone"
alias gcm="git commit -m"
alias gd="git diff"
alias gds="git diff --staged"
alias gg="git pull"
alias gk="gitk --all&"
alias gl="git log"
alias glp="git log -p"
alias gls="git log --oneline"
alias glv="git log --oneline --graph"
alias go="git checkout "
alias gp="git push"
alias grh="git reset HEAD"
alias gs="git status "
alias gsa="git stash apply"
alias gsd="git stash drop"
alias gsh="git show"
alias gsl="git stash list"
alias gsp="git stash pop"
alias gss="git stash save"
alias gssh="git stash show -p"
alias gst="git stash"
alias gt="git tag -l"
alias gtd="git tag -d"
alias gx="gitx --all"
alias nah="git reset --hard; git clean -df;"
alias wip='git add . && git commit -m "wip"'
alias got="git "
alias get="git "
alias gtower="gittower git rev-parse --show-toplevel"

# Show mount command output pretty and human readable
alias lsmount="mount |column -t"

# Enable aliases to be sudo'ed
alias sudo="sudo "
alias reboot="sudo reboot"

# find top 5 big files
alias findbig="find . -type f -exec ls -s {} \; | sort -n -r | head -5"

# lists size of folders in ./
alias foldersize="du -d 1|sort -n|cut -f2|tr '\n' '\0'|xargs -0 du -sh 2>/dev/null"

# human df
alias df="df -h"

function db {
    if [ "$1" = "refresh" ]; then
        mysql -uroot -p -e "drop database $2; create database $2; use $2; source $3"
    elif [ "$1" = "create" ]; then
        mysql -uroot -p -e "create database $2"
    elif [ "$1" = "drop" ]; then
        mysql -uroot -p -e "drop database $2"
    fi
}

# Print Source Code
alias printcode="a2ps -1 --line-numbers=1 -g -E"

# GPG configuration
export GPG_TTY=$(tty)

# PyEnv
if [ -d "$HOME/.pyenv" ]; then
    export PYENV_ROOT="$HOME/.pyenv"
    command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
fi

# GitIgnore
function gi() { curl -sL https://www.toptal.com/developers/gitignore/api/$@ ;}

_gitignoreio_get_command_list() {
  curl -sL https://www.toptal.com/developers/gitignore/api/list | tr "," "\n"
}

_gitignoreio () {
  compset -P '*,'
  compadd -S '' `_gitignoreio_get_command_list`
}

# GnuPG
export GPGKEY=8060A02E

# Source OS-specific configuration (must come before tmux.zsh so Homebrew tools are in PATH)
[[ -f ~/.zshrc.os ]] && source ~/.zshrc.os

# Source local configuration if it exists
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# Tmux auto-attach and aliases
[[ -f ~/.tmux.zsh ]] && source ~/.tmux.zsh

# Source Oh My Zsh (must come after OS and local configs so plugins+= takes effect)
source $ZSH/oh-my-zsh.sh

# Register completions (must come after oh-my-zsh.sh which provides compdef)
compdef _gitignoreio gi

# zsh-history-substring-search keybindings
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey -M vicmd 'k' history-substring-search-up
bindkey -M vicmd 'j' history-substring-search-down

# FZF Configuration
if command -v fzf &>/dev/null; then
    if command -v fd &>/dev/null; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
        export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
    fi

    export FZF_DEFAULT_OPTS='
      --height 40%
      --layout=reverse
      --border=rounded
      --info=inline
      --bind="ctrl-/:toggle-preview"
      --color=fg:#cdd6f4,bg:#1e1e2e,hl:#f38ba8
      --color=fg+:#cdd6f4,bg+:#313244,hl+:#f38ba8
      --color=info:#cba6f7,prompt:#89b4fa,pointer:#f5c2e7
      --color=marker:#a6e3a1,spinner:#f5c2e7,header:#94e2d5
    '

    if command -v bat &>/dev/null; then
        export FZF_CTRL_T_OPTS='--preview "bat --color=always --style=numbers --line-range=:50 {}" --preview-window=right:60%'
    else
        export FZF_CTRL_T_OPTS='--preview "cat {}" --preview-window=right:60%:wrap'
    fi

    export FZF_ALT_C_OPTS='--preview "ls -la --color {}"'
    export FZF_CTRL_R_OPTS='--sort --exact'

    [[ -f ~/.fzf.zsh ]] && source ~/.fzf.zsh
fi

# fzf-tab configuration
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:*' switch-group ',' '.'
