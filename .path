export PATH=.:./bin:/usr/local/mysql/bin:/usr/local/sbin:~/bin:/usr/local/bin:~/.composer/vendor/bin:$PATH

if [[ "$(uname )" == "Darwin" ]]; then
    export PATH=$(brew --prefix coreutils)/libexec/gnubin:/Library/TeX/Distributions/.DefaultTeX/Contents/Programs/texbin:/usr/local/gcc-arm/bin:$PATH;
fi
